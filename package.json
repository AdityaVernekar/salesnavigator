{
  "name": "salesnav",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:e2e-smoke": "node scripts/e2e-smoke.mjs",
    "test:agent-runtime-smoke": "node scripts/agent-runtime-config-smoke.mjs",
    "worker:nest": "TS_NODE_PROJECT=apps/worker-backend/tsconfig.json node -r dotenv/config -r ts-node/register/transpile-only -r tsconfig-paths/register apps/worker-backend/src/main.ts",
    "worker:nest:dev": "nodemon --watch apps --watch src --watch scripts --ext ts,js,json --exec \"npm run worker:nest\"",
    "worker:service": "TS_NODE_PROJECT=tsconfig.worker.json TS_NODE_COMPILER_OPTIONS='{\"module\":\"commonjs\"}' node -r dotenv/config -r ts-node/register/transpile-only -r tsconfig-paths/register scripts/worker-service.ts",
    "worker:service:once": "TS_NODE_PROJECT=tsconfig.worker.json TS_NODE_COMPILER_OPTIONS='{\"module\":\"commonjs\"}' node -r dotenv/config -r ts-node/register/transpile-only -r tsconfig-paths/register scripts/worker-service.ts --single-cycle"
  },
  "dependencies": {
    "@composio/core": "^0.6.4",
    "@hookform/resolvers": "^5.2.2",
    "@mastra/core": "^1.9.0",
    "@mastra/libsql": "^1.6.3",
    "@mastra/memory": "^1.6.0",
    "@mastra/pg": "^1.7.1",
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-express": "^11.1.6",
    "@supabase/supabase-js": "^2.98.0",
    "@tanstack/react-query": "^5.90.21",
    "@upstash/redis": "^1.36.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "exa-js": "^2.7.0",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "mastra": "^1.3.6",
    "nodemon": "^3.1.14",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
